# Production Environment Variables for Render
# Update these values with your production database details

NODE_ENV=production
PORT=10000

# Production Database (update with your Render PostgreSQL credentials)
DB_HOST=your-render-postgres-host.onrender.com
DB_PORT=5432
DB_NAME=ai_agent_platform
DB_USER=postgres
DB_PASSWORD=your-secure-password-here

# CORS: Update with your Vercel frontend URL
CORS_ORIGIN=https://your-project-name.vercel.app
